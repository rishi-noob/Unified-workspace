# Database (SQLite — file created next to cwd when running apps/api)
# No Postgres/Redis required for local MVP

# JWT
JWT_SECRET=unified_ticketing_jwt_secret_key_32chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Inbound mail (Gmail / IMAP) — tickets created from UNSEEN messages
# Use a Google "App password" (not your normal password) if 2FA is on.
IMAP_ENABLED=false
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=rishabhathrit@gmail.com
IMAP_PASSWORD=your_16_char_app_password
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_MS=60000

# Legacy aliases (also read if IMAP_* not set)
SMTP_HOST=imap.gmail.com
SMTP_PORT=993
SMTP_USER=rishabhathrit@gmail.com
SMTP_PASSWORD=app_specific_password
SMTP_MAILBOX=INBOX
SMTP_POLL_INTERVAL_MS=60000
SMTP_TLS=true

# Outbound email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=helpdesk@company.com
MAIL_PASSWORD=app_specific_password
MAIL_FROM="Helpdesk <helpdesk@company.com>"

# Freshdesk
FRESHDESK_DOMAIN=yourcompany.freshdesk.com
FRESHDESK_API_KEY=your_freshdesk_api_key
FRESHDESK_WEBHOOK_SECRET=your_hmac_secret

# Gemini AI (optional — keyword rules work without this)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_CLASSIFY=gemini-2.0-flash
GEMINI_MODEL_DRAFT=gemini-2.0-flash

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:4000

# Slack
SLACK_BOT_TOKEN=xoxb-placeholder
SLACK_CHANNEL_ALERTS=#helpdesk-alerts
