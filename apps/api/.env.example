# Database (SQLite — file created next to cwd when running apps/api)
# No Postgres/Redis required for local MVP

# JWT
JWT_SECRET=unified_ticketing_jwt_secret_key_32chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Inbound mail (Gmail / IMAP) — UNSEEN + new UIDs (read mail still ingested)
# Use a Google "App password" (not your normal password) if 2FA is on.
# UID cursor file defaults to apps/api/mail-ingest-uid.state.json (stable; not process.cwd).
# IMAP_UID_STATE_FILE=C:/path/mail-ingest-uid.state.json
IMAP_ENABLED=false
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=rishabhathrit@gmail.com
IMAP_PASSWORD=your_16_char_app_password
IMAP_MAILBOX=INBOX
# ~25s default; use 20000–30000 for near-real-time without hammering IMAP
IMAP_POLL_INTERVAL_MS=25000
# Max messages processed per poll (newest first). Only used when many UIDs match in one poll.
# IMAP_MAX_MESSAGES_PER_POLL=50
# Set true only if you want OLD unread mail to become tickets too (default: new UID > cursor only).
# IMAP_INCLUDE_UNSEEN_BACKLOG=false
# Idle socket timeout (ms). ImapFlow default 300000 (5m) can kill long polls; we use 900000 in code.
# Set to 0 to disable socket idle timeout (Node behavior).
# IMAP_SOCKET_TIMEOUT_MS=900000

# Legacy aliases (also read if IMAP_* not set)
SMTP_HOST=imap.gmail.com
SMTP_PORT=993
SMTP_USER=rishabhathrit@gmail.com
SMTP_PASSWORD=app_specific_password
SMTP_MAILBOX=INBOX
SMTP_POLL_INTERVAL_MS=25000
SMTP_TLS=true

# Outbound email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=helpdesk@company.com
MAIL_PASSWORD=app_specific_password
MAIL_FROM="Helpdesk <helpdesk@company.com>"

# Freshdesk
FRESHDESK_DOMAIN=yourcompany.freshdesk.com
FRESHDESK_API_KEY=your_freshdesk_api_key
FRESHDESK_WEBHOOK_SECRET=your_hmac_secret

# Gemini AI (optional — keyword rules work without this)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_CLASSIFY=gemini-2.0-flash
GEMINI_MODEL_DRAFT=gemini-2.0-flash
# false = never call Gemini for classification (keywords only; avoids 429 quota noise)
GEMINI_CLASSIFY_ENABLED=true

# Ingest: skip noreply / bulk / auto-replies (set false only if you need every message ticketed)
IMAP_INGEST_SKIP_BULK=true

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:4000

# Slack
SLACK_BOT_TOKEN=xoxb-placeholder
SLACK_CHANNEL_ALERTS=#helpdesk-alerts
