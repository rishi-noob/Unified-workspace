# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ticketing
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=changeme_strong_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password

# JWT
JWT_SECRET=changeme_jwt_secret_min_32_chars_long_enough
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# SMTP / IMAP
SMTP_HOST=imap.gmail.com
SMTP_PORT=993
SMTP_USER=helpdesk@company.com
SMTP_PASSWORD=app_specific_password
SMTP_MAILBOX=INBOX
SMTP_POLL_INTERVAL_MS=30000
SMTP_TLS=true

# Outbound email (for notifications)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=helpdesk@company.com
MAIL_PASSWORD=app_specific_password
MAIL_FROM="Helpdesk <helpdesk@company.com>"

# Freshdesk
FRESHDESK_DOMAIN=yourcompany.freshdesk.com
FRESHDESK_API_KEY=your_freshdesk_api_key
FRESHDESK_WEBHOOK_SECRET=your_hmac_secret

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL_CLASSIFY=gpt-4o-mini
OPENAI_MODEL_DRAFT=gpt-4o

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000

# Slack (optional notifications)
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ALERTS=#helpdesk-alerts

# RabbitMQ
RABBITMQ_URL=amqp://ticketing:changeme_rabbitmq_password@localhost:5672
